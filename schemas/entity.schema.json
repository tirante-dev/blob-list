{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tirante-dev/blob-list/schemas/entity.schema.json",
  "title": "Blob attribution entity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "category",
    "status",
    "addresses"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "rollup",
        "validium",
        "da_provider",
        "bridge",
        "infra",
        "wallet",
        "exchange",
        "research",
        "individual",
        "unknown"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "deprecated"]
    },
    "description": {
      "type": "string"
    },
    "website": {
      "type": "string",
      "format": "uri"
    },
    "chain_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["caip2", "relationship"],
        "properties": {
          "caip2": {
            "$ref": "#/$defs/caip2"
          },
          "relationship": {
            "type": "string",
            "enum": [
              "canonical_chain",
              "settlement_chain",
              "parent_chain",
              "related_chain"
            ]
          }
        }
      },
      "uniqueItems": true
    },
    "icon": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "chain_ref"],
          "properties": {
            "mode": {
              "const": "chainlist"
            },
            "chain_ref": {
              "$ref": "#/$defs/caip2"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "source", "license", "source_url"],
          "properties": {
            "mode": {
              "const": "local"
            },
            "source": {
              "type": "string",
              "pattern": "^icons/local/[A-Za-z0-9._/-]+\\.svg$"
            },
            "license": {
              "type": "string",
              "minLength": 1
            },
            "source_url": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      ]
    },
    "addresses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/address_claim"
      }
    }
  },
  "$defs": {
    "caip2": {
      "type": "string",
      "pattern": "^eip155-[0-9]+$"
    },
    "evm_address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "tx_hash": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "block_range_start": {
      "type": "object",
      "additionalProperties": false,
      "required": ["block"],
      "properties": {
        "block": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "block_range_end": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["block"],
          "properties": {
            "block": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "documentation",
            "announcement",
            "verified_contract",
            "transaction",
            "analysis",
            "repository",
            "dashboard"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "submission_chain": {
          "$ref": "#/$defs/caip2"
        },
        "tx_hash": {
          "$ref": "#/$defs/tx_hash"
        }
      }
    },
    "address_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "submission_chain",
        "address",
        "role",
        "label",
        "status",
        "confidence",
        "valid_from",
        "valid_to",
        "evidence"
      ],
      "properties": {
        "submission_chain": {
          "$ref": "#/$defs/caip2"
        },
        "address": {
          "$ref": "#/$defs/evm_address"
        },
        "role": {
          "type": "string",
          "enum": [
            "batcher",
            "sequencer",
            "proposer",
            "relayer",
            "bridge",
            "inbox",
            "outbox",
            "deployer",
            "operator",
            "paymaster",
            "unknown"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive", "deprecated"]
        },
        "confidence": {
          "type": "string",
          "enum": ["confirmed", "probable", "inferred", "disputed"]
        },
        "valid_from": {
          "$ref": "#/$defs/block_range_start"
        },
        "valid_to": {
          "$ref": "#/$defs/block_range_end"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      }
    }
  }
}
