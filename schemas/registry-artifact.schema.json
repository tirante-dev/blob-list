{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ahkc4/blob-list/schemas/registry-artifact.schema.json",
  "title": "Blob attribution registry artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "chainlist", "entities"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "chainlist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit"],
      "properties": {
        "repository": {
          "type": "string"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        }
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "entity.schema.json"
      }
    }
  }
}
